      <p class="text-slate-500 text-xs font-medium uppercase tracking-wide">Valid</p>
      <p id="stat-valid" class="text-2xl font-bold text-emerald-600 mt-1">0</p>
     </div>
     <div class="bg-white rounded-xl p-4 shadow-sm border border-slate-100">
      <p class="text-slate-500 text-xs font-medium uppercase tracking-wide">Tidak Valid</p>
      <p id="stat-invalid" class="text-2xl font-bold text-red-600 mt-1">0</p>
