          <th class="px-6 py-4 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Mata Kuliah</th>
          <th class="px-6 py-4 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Hasil Validasi</th>
          <th class="px-6 py-4 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Keterangan</th>
         </tr>
        </thead>
        <tbody id="table-body" class="divide-y divide-slate-100">
        </tbody>
       </table>
      </div><!-- Empty Search State -->
      <div id="empty-search" class="p-12 text-center" style="display: none;">
       <div class="w-16 h-16 rounded-full bg-slate-100 flex items-center justify-center mx-auto mb-4">
